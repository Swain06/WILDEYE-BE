# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=wildeye

# Models live in backend/trained_models/
WILDLIFE_MODEL_PATH=trained_models/WildlifeDetection.pt
# Poaching detection model (e.g. from runs/detect/poaching_detection/weights/best.pt → copy to trained_models/)
POACHING_MODEL_PATH=trained_models/PoachingDetection.pt
# Wildfire image classifier (PyTorch .pth from Colab forestfire CNN)
WILDFIRE_MODEL_PATH=trained_models/WildfirePrediction.pth
# Fire risk from xlsx/CSV dataset (firepredf.ipynb): RandomForest + StandardScaler
FIRE_MODEL_PATH=trained_models/fire_model.joblib
FIRE_SCALER_PATH=trained_models/fire_scaler.joblib
# Habitat suitability (RandomForest from Colab untitled49.py)
HABITAT_MODEL_PATH=trained_models/HabitatSuitability.pt

# Cloudinary — image storage for uploaded detection/poaching/fire images
# Sign up free at https://cloudinary.com and get these from your Dashboard
CLOUDINARY_CLOUD_NAME=WILDEYE
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# OpenWeatherMap — used for the 7-day fire risk forecast
# Free tier at https://openweathermap.org/api — generate a key and paste it here
OPENWEATHER_API_KEY=your_openweather_api_key

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# Telegram Bot (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Gmail SMTP — use a 16-character App Password (not your regular password)
# Enable 2-Step Verification first: https://myaccount.google.com/security
# Then generate an App Password: https://myaccount.google.com/apppasswords
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_16char_app_password
# Email address that receives poaching alerts (can be same as SMTP_USER or different)
ALERT_RECIPIENT=ranger@example.com

# Grok (xAI) — AI Ranger Chatbot
# Get your free key at: https://console.x.ai/
GROK_API_KEY=your_grok_api_key_here

# NewsAPI — Wildlife News & Awareness
NEWS_API_KEY=your_newsapi_key_here

# NASA FIRMS API key — get free at https://firms.modaps.eosdis.nasa.gov/api/area/
NASA_FIRMS_API_KEY=your_nasa_firms_key_here

# Bounding box for your monitoring region (default: India)
# Format: west,south,east,north
FIRMS_BBOX=68.0,8.0,97.0,37.0

# How often to auto-refresh fire data (in minutes)
FIRMS_REFRESH_INTERVAL=180
